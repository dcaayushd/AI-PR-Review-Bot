LLM_PROVIDER=openai
OPENAI_API_KEY=sk...
# Or use Gemini instead:
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=AIza...

GITHUB_APP_ID=123456
# Download this private key from GitHub App settings after you create the app.
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.private-key.pem
GITHUB_WEBHOOK_SECRET=change-me

DATABASE_URL=sqlite:///./runtime/reviews.db
WORKSPACE_ROOT=./runtime/workspaces
MAX_PARALLEL_REVIEWS=4
MAX_PENDING_REVIEWS=32
MAX_REPO_ACTIVE_REVIEWS=6
CANCEL_SUPERSEDED_REVIEWS=true
GIT_FETCH_TIMEOUT_SECONDS=180
GIT_FETCH_DEPTH=32

HOST=0.0.0.0
PORT=8000
PUBLIC_BASE_URL=
LOG_LEVEL=INFO
